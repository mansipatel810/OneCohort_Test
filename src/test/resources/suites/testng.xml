<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  ╔══════════════════════════════════════════════════════════════════════════╗
  ║           OneCohort — Consolidated Test Suite (~93 tests)               ║
  ║           Organised by feature area / user role                         ║
  ╠══════════════════════════════════════════════════════════════════════════╣
  ║  Run full suite        :  mvn test                                      ║
  ║  Run smoke tests only  :  mvn test -Dgroups=smoke                       ║
  ║  Run by role           :  mvn test -Dgroups=manager                     ║
  ║                                                                          ║
  ║  Available @Test groups                                                  ║
  ║  smoke        — Critical-path tests (Login + dashboards)                ║
  ║  regression   — Full suite (all tests)                                  ║
  ║  functional   — Feature tests (CRUD, search, filter)                    ║
  ║  superadmin   — Tests run under the Super Admin role                    ║
  ║  manager      — Tests run under the Manager role                        ║
  ║  leader       — Tests run under the Leader role                         ║
  ║  batchowner   — Tests run under the Batch Owner role                    ║
  ║  cr           — Tests run under the CR role                             ║
  ║  cohort       — Cohort management tests                                 ║
  ║  analytics    — Training analytics tests                                ║
  ║  systemconfig — System Configuration page tests                         ║
  ╚══════════════════════════════════════════════════════════════════════════╝
-->
<suite name="OneCohort Test Suite" verbose="1">

    <listeners>
        <listener class-name="com.cts.mfrp.onecohort.utils.ExtentReportListener"/>
        <listener class-name="com.cts.mfrp.onecohort.listeners.TestListener"/>
    </listeners>

    <!-- ════════════════════════════════════════════════════════════════
         AUTHENTICATION — 8 tests
         Tests positive login for all roles + key validation alerts.
         ════════════════════════════════════════════════════════════════ -->
    <test name="Login Tests">
        <classes>
            <class name="com.cts.mfrp.onecohort.tests.LoginTest"/>
        </classes>
    </test>

    <!-- ════════════════════════════════════════════════════════════════
         SUPER ADMIN — 10 tests
         Dashboard, sidebar navigation, badge, KPI, batch owners, managers, system config, logout.
         ════════════════════════════════════════════════════════════════ -->
    <test name="Super Admin Tests">
        <classes>
            <class name="com.cts.mfrp.onecohort.tests.SuperAdminTest"/>
        </classes>
    </test>

    <!-- ════════════════════════════════════════════════════════════════
         COHORT MANAGEMENT — 12 tests
         Page load, table columns, search, create/edit modals, deep dive, filters, badges, cancel.
         ════════════════════════════════════════════════════════════════ -->
    <test name="Cohort Management Tests">
        <classes>
            <class name="com.cts.mfrp.onecohort.tests.cohort.CohortManagementTest"/>
        </classes>
    </test>

    <!-- ════════════════════════════════════════════════════════════════
         TRAINEE MANAGEMENT — 6 tests
         Add Trainee button, modal, fields, form validation, cohort heading, summary cards.
         ════════════════════════════════════════════════════════════════ -->
    <test name="Trainee Tests">
        <classes>
            <class name="com.cts.mfrp.onecohort.tests.cohort.TraineeTest"/>
        </classes>
    </test>

    <!-- ════════════════════════════════════════════════════════════════
         MANAGER ROLE — 11 tests
         Dashboard, navigation, Managers page, create modal, KPI numbers,
         error check, modal fields, filter tabs, login validation.
         ════════════════════════════════════════════════════════════════ -->
    <test name="Manager Tests">
        <classes>
            <class name="com.cts.mfrp.onecohort.tests.managers.ManagerTest"/>
        </classes>
    </test>

    <!-- ════════════════════════════════════════════════════════════════
         LEADER ROLE — 7 tests
         Dashboard, sidebar navigation, no error, KPI numbers, logo, login validation.
         ════════════════════════════════════════════════════════════════ -->
    <test name="Leader Tests">
        <classes>
            <class name="com.cts.mfrp.onecohort.tests.leader.LeaderTest"/>
        </classes>
    </test>

    <!-- ════════════════════════════════════════════════════════════════
         BATCH OWNER ROLE — 13 tests
         Dashboard, summary cards, sidebar, cohort list, search, filter,
         cohort detail, timeline, evaluations, trainees, progress, login validation.
         ════════════════════════════════════════════════════════════════ -->
    <test name="Batch Owner Tests">
        <classes>
            <class name="com.cts.mfrp.onecohort.tests.batchowners.BatchOwnerTest"/>
        </classes>
    </test>

    <!-- ════════════════════════════════════════════════════════════════
         CR ROLE — 7 tests
         Dashboard URL, metadata panel, trainees table, read-only access,
         training timeline, evaluations, overall progress.
         ════════════════════════════════════════════════════════════════ -->
    <test name="CR Tests">
        <classes>
            <class name="com.cts.mfrp.onecohort.tests.cr.CRTest"/>
        </classes>
    </test>

    <!-- ════════════════════════════════════════════════════════════════
         TRAINING ANALYTICS — 8 tests
         Page load, chart rendering, cohort cards, percentage data,
         service line filter, on-track indicator, behind indicator, back navigation.
         ════════════════════════════════════════════════════════════════ -->
    <test name="Analytics Tests">
        <classes>
            <class name="com.cts.mfrp.onecohort.tests.analytics.AnalyticsTest"/>
        </classes>
    </test>

    <!-- ════════════════════════════════════════════════════════════════
         SYSTEM CONFIGURATION — 11 tests
         Page load, heading, subtitle, card count, create buttons,
         each modal opens, cancel closes modal, all cards visible.
         ════════════════════════════════════════════════════════════════ -->
    <test name="System Config Tests">
        <classes>
            <class name="com.cts.mfrp.onecohort.tests.SystemConfigTest"/>
        </classes>
    </test>

</suite>
