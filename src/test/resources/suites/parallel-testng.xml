<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="OneCohort Parallel Suite" parallel="classes" thread-count="3" verbose="1">

    <listeners>
        <listener class-name="com.cts.mfrp.onecohort.utils.ExtentReportListener"/>
    </listeners>

    <test name="Parallel Execution">
        <classes>
            <class name="com.cts.mfrp.onecohort.tests.LoginTest"/>
            <class name="com.cts.mfrp.onecohort.tests.EmployeeTest"/>
            <class name="com.cts.mfrp.onecohort.tests.LeaveTest"/>
        </classes>
    </test>

</suite>
